# OmniCore 环境变量配置

# === 大模型 API 配置 ===
# 支持 OpenAI / Anthropic / Gemini 等，通过 LiteLLM 统一调用
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
MINIMAX_API_KEY=your-minimax-key

# === 网络代理（可选）===
# 默认不继承系统代理，避免外部 shell 里的脏代理影响模型请求。
# 如果需要代理，请在这里显式配置项目代理。
ALLOW_SYSTEM_PROXY=false
OMNICORE_HTTP_PROXY=http://127.0.0.1:7078
OMNICORE_HTTPS_PROXY=http://127.0.0.1:7078
OMNICORE_ALL_PROXY=
OMNICORE_NO_PROXY=localhost,127.0.0.1,::1

# 默认使用的模型 (可选: gpt-4o, claude-3-opus, gemini-pro 等)
DEFAULT_MODEL=gpt-4o
# 可选锁定厂家: gemini/kimi/openai/deepseek/minimax
PREFERRED_PROVIDER=

# === LLM 调用配置 ===
# 默认 max_tokens（推荐 65535 以获得最大输出能力）
# 注意：不同模型有不同的 max_tokens 限制，系统会自动调整
LLM_MAX_TOKENS=65535
# Router 专用 max_tokens（路由分析通常需要更多 tokens）
LLM_ROUTER_MAX_TOKENS=65535
# 普通对话 max_tokens
LLM_CHAT_MAX_TOKENS=32768

# === 本地路径配置 ===
# 用户桌面路径 (用于文件输出)
USER_DESKTOP_PATH=C:/Users/YourName/Desktop

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma

# === 安全配置 ===
# 高危操作是否需要人类确认 (true/false)
REQUIRE_HUMAN_CONFIRM=true

# === 调试配置 ===
DEBUG_MODE=false
LOG_LEVEL=INFO

# === 浏览器执行优化 ===
# 快速模式：减少随机延迟，优先吞吐
BROWSER_FAST_MODE=true
# 阻断图片/字体/媒体资源，提升网页交互速度
BLOCK_HEAVY_RESOURCES=true
# 纯读页面时优先静态抓取，避免启动浏览器
STATIC_FETCH_ENABLED=true

# === 搜索引擎 API 配置（可选，用于提升搜索可靠性）===
# SerpAPI - 推荐使用，支持 Google/Bing/Baidu 等多个搜索引擎
# 注册地址: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key

# Google Custom Search API - 备用方案
# 注册地址: https://developers.google.com/custom-search
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-custom-search-engine-id

# 注意：如果不配置这些 API，系统会自动降级到原生页面搜索
# 建议至少配置 SERPAPI_KEY 以获得最佳搜索体验

