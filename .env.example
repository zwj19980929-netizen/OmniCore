# OmniCore 环境变量配置

# === 大模型 API 配置 ===
# 支持 OpenAI / Anthropic / Gemini 等，通过 LiteLLM 统一调用
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key

# 默认使用的模型 (可选: gpt-4o, claude-3-opus, gemini-pro 等)
DEFAULT_MODEL=gpt-4o

# === 本地路径配置 ===
# 用户桌面路径 (用于文件输出)
USER_DESKTOP_PATH=C:/Users/YourName/Desktop

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma

# === 安全配置 ===
# 高危操作是否需要人类确认 (true/false)
REQUIRE_HUMAN_CONFIRM=true

# === 调试配置 ===
DEBUG_MODE=false
LOG_LEVEL=INFO

# === 浏览器执行优化 ===
# 快速模式：减少随机延迟，优先吞吐
BROWSER_FAST_MODE=true
# 阻断图片/字体/媒体资源，提升网页交互速度
BLOCK_HEAVY_RESOURCES=true
# 纯读页面时优先静态抓取，避免启动浏览器
STATIC_FETCH_ENABLED=true
